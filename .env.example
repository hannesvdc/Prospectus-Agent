# Prospectus-Agent environment variables — TEMPLATE (committed; no secrets here)
# Copy to .env and fill in. The real .env is gitignored.
# ---------------------------------------------------------------------------

# --- Secrets ---------------------------------------------------------------
ANTHROPIC_API_KEY=

# Optional: real mailbox verification via https://verifalia.com. These are HTTP
# Basic auth credentials (a "browser app" username/password pair), NOT a bearer
# API key. Only profiles with settings.verify_emails: true use them; blank = off.
VERIFALIA_USERNAME=
VERIFALIA_PASSWORD=

# --- Profile ---------------------------------------------------------------
# Describe your business + who to prospect in profile.yaml (see profile.example.yaml).
# PROFILE_PATH=profile.yaml

# --- Paths -----------------------------------------------------------------
# The agent runs from any working directory. Relative paths below resolve against
# the project home (this folder); set absolute paths to fix locations anywhere.
# Override the home explicitly with the PROSPECTUS_AGENT_HOME shell env var.
# Where draft digests (index.md / index.html) are written:
# OUTBOX_DIR=outbox

# --- Pipeline tunables -----------------------------------------------------
# Searcher (discovery + per-company research + profile refresh, with web search).
ANTHROPIC_MODEL=claude-haiku-4-5
# Fallback geographic focus. Prefer setting `region:` per profile (see
# profile.example.yaml); this is only used when a profile doesn't specify one.
TARGET_REGION=North America
FIT_SCORE_THRESHOLD=7
TARGET_COMPANY_COUNT=3
MAX_PER_SECTOR=2
# Comma-separated sector keys to exclude entirely. Valid keys: aerospace_defense,
# automotive, energy, life_sciences, materials_chemicals, semiconductors_electronics,
# climate_geoscience, finance, manufacturing_industrial, other.
AVOID_SECTORS=
# Largest company size to target: startup | small | mid | large | enterprise.
# Picks bigger than this are excluded (e.g. mid excludes large multinationals like GM).
MAX_COMPANY_SIZE=mid
# Max discovery rounds/run. The loop stops early once TARGET_COMPANY_COUNT is reached,
# so raising this only adds rounds on days that need to backfill dropped/unreachable
# companies — good days cost the same.
MAX_DISCOVERY_CALLS=3
# Cap the "don't repeat" hint sent to the model (DB filter still dedups fully).
DENY_LIST_LIMIT=150
# Re-fetch the ON profile from the web at most every N days.
PROFILE_REFRESH_DAYS=7
# Calendar days after you mark an email 'sent' before a follow-up is due.
FOLLOWUP_DAYS=5
DB_PATH=prospects.db
# Contact list per company: up to 3 senior people, ONE best address each (published >
# pattern-inferred from a real address on the domain > top guess), plus a generic inbox
# only as a fallback when no reliable personal address is found. Domains with no MX/A
# record are skipped (guaranteed bounce). GUESSES_PER_PERSON caps only the blind-guess
# fallback; keep it at 1 — extra format guesses per person just bounce.
MAX_PUBLIC_EMAILS=1
MAX_PEOPLE=3
GUESSES_PER_PERSON=1

# --- Auto-send (`--deliver`) -----------------------------------------------
# Sending address (both profiles send from the Open Numerics Google Workspace inbox).
AUTOSEND_FROM=hannesv@opennumerics.com
# Max company-emails delivered per run (start 10, ramp to 40 over week 1, then 100 if clean).
AUTOSEND_DAILY_MAX=10
# Max To+Bcc recipients per email.
AUTOSEND_MAX_RECIPIENTS=5
# Comma-separated profiles allowed to auto-send; others are dry-run only. ON first.
AUTOSEND_PROFILES=open-numerics
# Gmail OAuth (Internal app) — needed only once live sending is wired (dry-run needs none).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- Models ----------------------------------------------------------------
# Writer (drafts the actual emails; no web search). Sonnet's prose quality matters
# here and the output is short, so the cost stays tiny.
WRITER_MODEL=claude-sonnet-4-6
# Searcher model for mechanical steps (profile + scoring); defaults to ANTHROPIC_MODEL.
DISCOVERY_MODEL=claude-haiku-4-5
# NOTE: DISCOVERY_EFFORT / DRAFTING_EFFORT / SEARCH_CONTEXT_SIZE are ignored on the
# Anthropic path (Haiku 4.5 doesn't accept the effort parameter); kept for compat.
DISCOVERY_MAX_TOKENS=8000
DRAFT_MAX_TOKENS=4000
PROFILE_MAX_TOKENS=2000
