# Prospectus-Agent environment variables — TEMPLATE (committed; no secrets here)
# Copy to .env and fill in. The real .env is gitignored.
# ---------------------------------------------------------------------------

# --- Secrets ---------------------------------------------------------------
OPENAI_API_KEY=

# --- Open Numerics profile -------------------------------------------------
ON_WEBSITE_URL=https://opennumerics.com

# --- Sender identity (used in drafted emails + CAN-SPAM compliance) --------
# CAN-SPAM requires accurate sender identification and a valid physical
# postal address in every commercial email.
SENDER_NAME=Hannes Vandecasteele
SENDER_TITLE=Founder
SENDER_COMPANY=Open Numerics
SENDER_EMAIL=info@opennumerics.com
SENDER_PHYSICAL_ADDRESS=

# --- Pipeline tunables -----------------------------------------------------
OPENAI_MODEL=gpt-5.5
TARGET_REGION=North America
FIT_SCORE_THRESHOLD=7
TARGET_COMPANY_COUNT=5
MAX_DISCOVERY_CALLS=3
FOLLOWUP_BUSINESS_DAYS=5
DB_PATH=prospects.db
