# Prospectus-Agent environment variables — TEMPLATE (committed; no secrets here)
# Copy to .env and fill in. The real .env is gitignored.
# ---------------------------------------------------------------------------

# --- Secrets ---------------------------------------------------------------
OPENAI_API_KEY=

# --- Open Numerics profile -------------------------------------------------
ON_WEBSITE_URL=https://opennumerics.com

# --- Pipeline tunables -----------------------------------------------------
OPENAI_MODEL=gpt-5.5
TARGET_REGION=North America
FIT_SCORE_THRESHOLD=7
TARGET_COMPANY_COUNT=5
MAX_PER_SECTOR=2
# Comma-separated sector keys to exclude entirely. Valid keys: aerospace_defense,
# automotive, energy, life_sciences, materials_chemicals, semiconductors_electronics,
# climate_geoscience, finance, manufacturing_industrial, other.
AVOID_SECTORS=
# Largest company size to target: startup | small | mid | large | enterprise.
# Picks bigger than this are excluded (e.g. mid excludes large multinationals like GM).
MAX_COMPANY_SIZE=mid
MAX_DISCOVERY_CALLS=3
FOLLOWUP_BUSINESS_DAYS=5
DB_PATH=prospects.db
