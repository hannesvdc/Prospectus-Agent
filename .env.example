# Prospectus-Agent environment variables — TEMPLATE (committed; no secrets here)
# Copy to .env and fill in. The real .env is gitignored.
# ---------------------------------------------------------------------------

# --- Secrets ---------------------------------------------------------------
OPENAI_API_KEY=

# --- Profile ---------------------------------------------------------------
# Describe your business + who to prospect in profile.yaml (see profile.example.yaml).
# PROFILE_PATH=profile.yaml

# --- Paths -----------------------------------------------------------------
# The agent runs from any working directory. Relative paths below resolve against
# the project home (this folder); set absolute paths to fix locations anywhere.
# Override the home explicitly with the PROSPECTUS_AGENT_HOME shell env var.
# Where draft digests (index.md / index.html) are written:
# OUTBOX_DIR=outbox

# --- Pipeline tunables -----------------------------------------------------
OPENAI_MODEL=gpt-5.4-mini    # cheap default; gpt-5.4 / gpt-5.5 cost 2x / 6.6x more
TARGET_REGION=North America
FIT_SCORE_THRESHOLD=7
TARGET_COMPANY_COUNT=3
MAX_PER_SECTOR=2
# Comma-separated sector keys to exclude entirely. Valid keys: aerospace_defense,
# automotive, energy, life_sciences, materials_chemicals, semiconductors_electronics,
# climate_geoscience, finance, manufacturing_industrial, other.
AVOID_SECTORS=
# Largest company size to target: startup | small | mid | large | enterprise.
# Picks bigger than this are excluded (e.g. mid excludes large multinationals like GM).
MAX_COMPANY_SIZE=mid
MAX_DISCOVERY_CALLS=2
# Cap the "don't repeat" hint sent to the model (DB filter still dedups fully).
DENY_LIST_LIMIT=150
# Re-fetch the ON profile from the web at most every N days.
PROFILE_REFRESH_DAYS=7
FOLLOWUP_BUSINESS_DAYS=5
DB_PATH=prospects.db
# Contact list per company: 1 generic inbox + up to 3 senior people (1 address each).
MAX_PUBLIC_EMAILS=1
MAX_PEOPLE=3
GUESSES_PER_PERSON=1

# --- Token / cost controls -------------------------------------------------
# Reasoning effort (none|minimal|low|medium|high|xhigh). Lower = fewer tokens.
DISCOVERY_EFFORT=low
DRAFTING_EFFORT=low          # bump to medium/high if email quality dips
# Model for mechanical steps (profile + scoring); defaults to OPENAI_MODEL.
DISCOVERY_MODEL=gpt-5.4-mini
# How much web-search content enters context (low|medium|high).
SEARCH_CONTEXT_SIZE=low
DISCOVERY_MAX_TOKENS=8000
DRAFT_MAX_TOKENS=4000
PROFILE_MAX_TOKENS=2000
